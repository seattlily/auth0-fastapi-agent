# Copy this file to `.env` and fill in real values. The .env file is in
# .gitignore — never commit it.

# ---------- Auth0 ----------
# Get these from your Auth0 dashboard:
#   Applications -> [your Regular Web App] -> Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-app-client-id
AUTH0_CLIENT_SECRET=your-auth0-app-client-secret

# Optional: a SECOND Auth0 application dedicated to CIBA step-up.
# Required if your main app has Organizations Login Experience set to
# "Business Users Only" (organization_usage: require) — that mode is
# incompatible with the CIBA grant type on the same app, so CIBA must
# live on a sibling application. Same tenant, same users, same
# Guardian devices. If unset, the helper falls back to AUTH0_CLIENT_ID
# / AUTH0_CLIENT_SECRET above (single-app setup).
# AUTH0_CIBA_CLIENT_ID=your-ciba-app-client-id
# AUTH0_CIBA_CLIENT_SECRET=your-ciba-app-client-secret

# The audience of the CompassZero API. RBAC + "Add Permissions in the
# Access Token" must be ON for this API in the Auth0 dashboard so the
# `permissions` claim arrives populated. See AUTH0_API_DEFINITIONS.md.
AUTH0_AUDIENCE=https://compasszero.api

# ---------- Session ----------
# Cookie-signing key, used by both Starlette's SessionMiddleware and the
# auth0-fastapi SDK's session store. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=replace-with-32-bytes-of-hex

# Optional: where this app lives. The auth0-fastapi SDK uses it as the
# canonical app base URL. Default works for local dev.
# APP_BASE_URL=http://localhost:8000

# ---------- LLM ----------
# OpenAI API key (or any OpenAI-compatible provider).
OPENAI_API_KEY=sk-replace-me

# Optional: override the OpenAI base URL if you use a proxy or alternative
# provider that speaks the OpenAI Chat Completions API.
# Default is https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: pick a model. Default is gpt-4o-mini. Any chat model that
# supports function calling will work (gpt-4o, gpt-4o-mini, gpt-4.1-mini, etc).
# LLM_MODEL=gpt-4o-mini
